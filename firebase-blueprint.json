{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "photoURL": { "type": "string", "description": "URL to user's profile picture" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email"]
    },
    "MusicLesson": {
      "title": "Music Lesson",
      "description": "Represents a learning module or session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["Beginner", "Intermediate", "Advanced"] },
        "category": { "type": "string" },
        "thumbnailUrl": { "type": "string" }
      },
      "required": ["title", "difficulty"]
    },
    "UserProgress": {
      "title": "User Progress",
      "description": "Tracks user's progress in lessons",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "lessonId": { "type": "string" },
        "completed": { "type": "boolean" },
        "lastAccessed": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "lessonId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Private user profile data"
    },
    "/lessons/{lessonId}": {
      "schema": "MusicLesson",
      "description": "Public music lessons"
    },
    "/users/{userId}/progress/{lessonId}": {
      "schema": "UserProgress",
      "description": "User-specific lesson progress"
    }
  }
}
